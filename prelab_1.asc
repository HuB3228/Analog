TEXT -1368 -632 Left 2 !* --- 1. FREQUENCY of RAMP and SQUARE ---\n.meas TRAN T_Ramp TRIG V(RAMP)=2.5 RISE=1 TARG V(RAMP)=2.5 RISE=2\n.meas TRAN F_Ramp PARAM 1/T_Ramp\n.meas TRAN T_Sqr TRIG V(SCHMIDT)=2.5 RISE=1 TARG V(SCHMIDT)=2.5 RISE=2\n.meas TRAN F_Sqr PARAM 1/T_Sqr\n \n* --- 2. AMPLITUDE of RAMP ---\n.meas TRAN Ramp_Max MAX V(RAMP)\n.meas TRAN Ramp_Min MIN V(RAMP)\n.meas TRAN Ramp_Amp PARAM Ramp_Max-Ramp_Min\n \n* --- 3. RAMP_B (After Capacitor) Stats ---\n.meas TRAN RB_Max MAX V(RAMP_B)\n.meas TRAN RB_Min MIN V(RAMP_B)\n.meas TRAN RB_Amp PARAM RB_Max-RB_Min\n.meas TRAN RB_Bias AVG V(RAMP_B)\n.meas TRAN T_RB TRIG V(RAMP_B)=2.5 RISE=1 TARG V(RAMP_B)=2.5 RISE=2\n.meas TRAN F_RB PARAM 1/T_RB\n \n* --- 4. PWM Measurements ---\n.meas TRAN T_PWM TRIG V(PWM)=2.5 RISE=1 TARG V(PWM)=2.5 RISE=2\n.meas TRAN F_PWM PARAM 1/T_PWM\n.meas TRAN T_On TRIG V(PWM)=2.5 RISE=1 TARG V(PWM)=2.5 FALL=1\n.meas TRAN DutyCycle PARAM (T_On/T_PWM)*100
