TEXT -3672 -936 Left 2 !* --- 1. FREQUENCY of RAMP and SQUARE ---\n.meas TRAN T_Ramp TRIG V(RAMP)=2.5 RISE=1 TARG V(RAMP)=2.5 RISE=2\n.meas TRAN F_Ramp PARAM 1/T_Ramp\n.meas TRAN T_Sqr TRIG V(SCHMIDT)=2.5 RISE=1 TARG V(SCHMIDT)=2.5 RISE=2\n.meas TRAN F_Sqr PARAM 1/T_Sqr\n \n* --- 2. AMPLITUDE of RAMP ---\n.meas TRAN Ramp_Max MAX V(RAMP)\n.meas TRAN Ramp_Min MIN V(RAMP)\n.meas TRAN Ramp_Amp PARAM Ramp_Max-Ramp_Min\n \n* --- 3. RAMP_B (After Capacitor) Stats ---\n.meas TRAN RB_Max MAX V(RAMP_B)\n.meas TRAN RB_Min MIN V(RAMP_B)\n.meas TRAN RB_Amp PARAM RB_Max-RB_Min\n.meas TRAN RB_Bias AVG V(RAMP_B)\n.meas TRAN T_RB TRIG V(RAMP_B)=2.5 RISE=1 TARG V(RAMP_B)=2.5 RISE=2\n.meas TRAN F_RB PARAM 1/T_RB\n \n* --- 4. PWM Measurements ---\n.meas TRAN T_PWM TRIG V(PWM)=2.5 RISE=1 TARG V(PWM)=2.5 RISE=2\n.meas TRAN F_PWM PARAM 1/T_PWM\n.meas TRAN T_On TRIG V(PWM)=2.5 RISE=1 TARG V(PWM)=2.5 FALL=1\n.meas TRAN DutyCycle PARAM (T_On/T_PWM)*100
TEXT -872 248 Left 2 !.include CD4069UB.cir
TEXT -872 304 Left 2 !.include SN74AHC00.cir
TEXT -952 -1320 Left 2 !* -------- NON OVERLAP TIME --------\n.meas TRAN T_Gp_Fall TRIG V(Vgate_p)=2.5 FALL=1\n.meas TRAN T_Gn_Rise TARG V(Vgate_n)=2.5 RISE=1\n.meas TRAN DeadTime_HL PARAM T_Gn_Rise - T_Gp_Fall\n \n.meas TRAN T_Gn_Fall TRIG V(Vgate_n)=2.5 FALL=1\n.meas TRAN T_Gp_Rise TARG V(Vgate_p)=2.5 RISE=1\n.meas TRAN DeadTime_LH PARAM T_Gp_Rise - T_Gn_Fall\n \n* -------- VSW FREQUENCY --------\n.meas TRAN T_SW TRIG V(Vsw)=2.5 RISE=1 TARG V(Vsw)=2.5 RISE=2\n.meas TRAN F_SW PARAM 1/T_SW\n \n* -------- VSW DUTY --------\n.meas TRAN T_On_SW TRIG V(Vsw)=2.5 RISE=1 TARG V(Vsw)=2.5 FALL=1\n.meas TRAN Duty_SW PARAM (T_On_SW/T_SW)*100\n \n* -------- PROPAGATION DELAY --------\n.meas TRAN T_PWM_Rise TRIG V(Vpwm)=2.5 RISE=1\n.meas TRAN T_SW_Rise  TARG V(Vsw)=2.5 RISE=1\n.meas TRAN Prop_Delay PARAM T_SW_Rise - T_PWM_Rise\n \n* -------- VOUT --------\n.meas TRAN Vout_Avg AVG V(Vout)\n.meas TRAN Vout_Max MAX V(Vout)\n.meas TRAN Vout_Min MIN V(Vout)\n.meas TRAN Vout_Ripple PARAM Vout_Max - Vout_Min\n \n* -------- VERIFY D --------\n.meas TRAN D_from_Vout PARAM (Vout_Avg/5)*100
